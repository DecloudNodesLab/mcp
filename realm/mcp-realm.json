{
  "realm": "${MCP_REALM_NAME}",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": false,

  "clients": [
    {
      "clientId": "${MCP_CLIENT_ID}",
      "name": "ChatGPT MCP",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "${MCP_CLIENT_SECRET}",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "implicitFlowEnabled": false,
      "redirectUris": [
        "*"
      ],
      "webOrigins": [
        "*"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "profile",
        "email",
        "roles",
        "web-origins"
      ],
      "optionalClientScopes": [
        "offline_access",
        "address",
        "phone",
        "microprofile-jwt"
      ]
    }
  ],

  "users": [
    {
      "username": "${MCP_LOGIN_USERNAME}",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "${MCP_LOGIN_PASSWORD}",
          "temporary": false
        }
      ]
    }
  ]
}
